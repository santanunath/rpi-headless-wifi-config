#cloud-config
hostname: raspberrypi
password: pi
chpasswd: { expire: False }
ssh_pwauth: True

write_files:
  - path: /etc/NetworkManager/system-connections/preconfigured-wifi.nmconnection
    permissions: "0600"
    content: |
      [connection]
      id=preconfigured-wifi
      type=wifi
      interface-name=wlan0

      [wifi]
      mode=infrastructure
      ssid=Airtel_rupr_4874

      [wifi-security]
      auth-alg=open
      key-mgmt=wpa-psk
      psk=Air@22344

      [ipv4]
      method=auto

      [ipv6]
      addr-gen-mode=default
      method=auto

runcmd:
  - [ systemctl, daemon-reload ]
  - [ systemctl, restart, NetworkManager ]

